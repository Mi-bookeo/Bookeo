# ══════════════════════════════════════
# BOOKEO · Variables de entorno Railway
# Copia este archivo como .env en local
# NUNCA subas .env a GitHub
# ══════════════════════════════════════

# Claude API
ANTHROPIC_API_KEY=sk-ant-api03-xxx

# Supabase
SUPABASE_URL=https://xxx.supabase.co
SUPABASE_ANON_KEY=eyJxxx
SUPABASE_SERVICE_KEY=eyJxxx

# Stripe
STRIPE_SECRET_KEY=sk_test_xxx
STRIPE_PUBLISHABLE_KEY=pk_test_xxx
STRIPE_WEBHOOK_SECRET=whsec_xxx

# Gelato
GELATO_API_KEY=xxx

# Google Drive OAuth
GOOGLE_CLIENT_ID=xxx.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=GOCSPX-xxx
GOOGLE_REDIRECT_URI=https://mibookeo.es/auth/callback

# Resend
RESEND_API_KEY=re_xxx

# Odoo (añadir cuando esté listo)
# ODOO_URL=https://mibookeo.odoo.com
# ODOO_API_KEY=xxx
# ODOO_DB=mibookeo

# Redis (Railway lo pone automático)
REDIS_URL=redis://localhost:6379

# Entorno
ENVIRONMENT=production
